# NexaMail — example environment
# Copy to .env and fill in. Never commit the real .env.

# ---- apps/web ----
NEXT_PUBLIC_APP_NAME=NexaMail
NEXT_PUBLIC_BRAND_NAVY=#0d1b2e
NEXT_PUBLIC_BRAND_AMBER=#f59e0b

# Server-only — URLs of internal services
IMAP_BRIDGE_URL=http://localhost:4001
AI_BRIDGE_URL=http://localhost:4002

# Shared service auth token (server-side only, rotate regularly)
INTERNAL_SERVICE_TOKEN=

# ---- services/imap-bridge ----
IMAP_BRIDGE_PORT=4001
IMAP_BRIDGE_LOG_LEVEL=info

# ---- services/ai-bridge ----
AI_BRIDGE_PORT=4002
AI_BRIDGE_LOG_LEVEL=info

# LLM provider — use whichever you configure; never commit real keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- data stores (fill per-environment) ----
DATABASE_URL=
REDIS_URL=
