# VoxMail — example environment
# Copy to .env and fill in. Never commit the real .env.

# ---- apps/web (public — safe in client bundle) ----
NEXT_PUBLIC_APP_NAME=VoxMail
NEXT_PUBLIC_BRAND_NAVY=#0d1b2e
NEXT_PUBLIC_BRAND_AMBER=#f59e0b

# ---- apps/web (server-only) ----
# Internal service URLs. In Docker compose these resolve to the service names.
IMAP_BRIDGE_URL=http://imap-bridge:4001
AI_BRIDGE_URL=http://ai-bridge:4002

# Shared bearer token between web and internal services.
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=

# Shared bearer token between the voxmail-tracking Cloudflare Worker and
# voxmail-ai's /track endpoint. Must match the secret set via
#   wrangler secret put TRACKING_WORKER_TOKEN
# in workers/tracking. Generate with: openssl rand -hex 32
TRACKING_WORKER_TOKEN=

# HMAC secret for signing one-click unsubscribe tokens in campaign emails.
# Rotating this will invalidate every already-delivered unsubscribe link.
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=

# Public base URL of voxmail-imap, without trailing slash. Recipients hit
# <this-url>/unsubscribe?token=... when clicking the footer link.
UNSUBSCRIBE_BASE_URL=https://imap.nexamail.voxtn.com

# ---- Stripe billing (Phase 6) ----
# sk_test_... in test mode, sk_live_... in live. Starts empty —
# fill in with your Stripe dashboard API key.
STRIPE_SECRET_KEY=
# whsec_... — created when you register a webhook endpoint in Stripe.
# Must match the signing secret of the endpoint pointing at
#   https://ai.nexamail.voxtn.com/stripe/webhook
STRIPE_WEBHOOK_SECRET=
# Price IDs for VoxMail Starter ($29) and Pro ($79). Populate after
# running the Stripe product setup (or copy the sandbox IDs below).
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
# Public URL of apps/web — used as base for Stripe Checkout success /
# cancel redirects.
APP_BASE_URL=http://localhost:3000

# ---- services/imap-bridge ----
IMAP_BRIDGE_PORT=4001
IMAP_BRIDGE_LOG_LEVEL=info

# ---- services/ai-bridge ----
AI_BRIDGE_PORT=4002
AI_BRIDGE_LOG_LEVEL=info

# ---- LLM providers (server-only) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Voice-to-email pipeline (voxmail-ai /voice-to-email) ----
# Sarvam Saaras STT — https://sarvam.ai
SARVAM_API_KEY=
# Gemini 2.0 Flash — https://ai.google.dev
GEMINI_API_KEY=

# ---- VoxTN Platform API (CRM source for voxmail-ai) ----
# Internal service on the Hetzner host, port 8011. Currently mocked in code
# until /contacts, /deals, /activities routes are added upstream.
VOXTN_PLATFORM_API_URL=http://host.docker.internal:8011
VOXTN_PLATFORM_API_KEY=

# ---- Data stores ----
# On the Hetzner host, Postgres and Redis bind to 127.0.0.1. Containers reach
# them via host.docker.internal. Compose must map this with:
#   extra_hosts: ["host.docker.internal:host-gateway"]
#
# DATABASE_URL shape:
#   postgresql://<user>:<password>@host.docker.internal:5432/<db>
DATABASE_URL=postgresql://nexamail_user:REPLACE_ME@host.docker.internal:5432/nexamail

# Redis: use DB index 4 (DBs 0/2/3 are used by other tenants on the shared host).
# Prefix all keys with voxmail: for extra isolation.
REDIS_URL=redis://host.docker.internal:6379/4
REDIS_KEY_PREFIX=voxmail:
