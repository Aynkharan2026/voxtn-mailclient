# apps/web — example environment
# Copy to apps/web/.env.local (gitignored) and fill in.
# Next.js loads .env.local automatically; do NOT commit real values.

# ---- voxmail services (server-only) ----
IMAP_BRIDGE_URL=https://imap.nexamail.voxtn.com
AI_BRIDGE_URL=https://ai.nexamail.voxtn.com
INTERNAL_SERVICE_TOKEN=

# Public URL of voxmail-ai — used by the browser to connect to Socket.io at
# wss://<this-url>/socket.io/. Shipped into the client bundle, safe to publish.
NEXT_PUBLIC_AI_BRIDGE_URL=https://ai.nexamail.voxtn.com

# ---- SMTP relay (VoxTN Mailcow — DCR-NM-011) ----
# voxmail-imap now reads these server-side from /opt/nexamail/.env; the
# apps/web `.env.local` doesn't need them unless you're running the
# imap-bridge locally. They're documented here so contributors running
# the full stack locally know what to set.
SMTP_HOST=208.79.219.189
SMTP_PORT=587
SMTP_USER=noreply@voxtn.com
SMTP_PASS=
SMTP_SECURE=false

# ---- Whitelabel / tenant branding ----
# Optional: when set, the root layout fetches this tenant's branding from
# voxmail-ai and injects --brand-primary as a CSS variable on <html>. If
# unset, the layout falls back to VoxTN defaults (navy + amber).
NEXT_PUBLIC_TENANT_SLUG=

# ---- Cal.com (VoxMail Booking) ----
# Base URL of the self-hosted Cal.com instance. Used both by the /api/cal/
# booking-url route handler and by the /book/[slug] page's embed.
CALCOM_BASE_URL=https://cal.voxtn.com
# Default Cal.com username for the "Insert Booking Link" button in the
# composer. Replaced by per-user resolution when we add a user model in
# Phase 4.1.
CALCOM_USERNAME=karan

# ---- Developer SMTP account (MVP — server action injects into every /send) ----
# Will be replaced by the account store in Phase 4 (DCR-NM-004).
# For Gmail: use an App Password, port 465, secure=true.
DEV_SMTP_HOST=
DEV_SMTP_PORT=465
DEV_SMTP_SECURE=true
DEV_SMTP_USER=
DEV_SMTP_PASS=
