# apps/web — example environment
# Copy to apps/web/.env.local (gitignored) and fill in.
# Next.js loads .env.local automatically; do NOT commit real values.

# ---- voxmail-imap (server-only) ----
IMAP_BRIDGE_URL=https://imap.nexamail.voxtn.com
INTERNAL_SERVICE_TOKEN=

# ---- Developer SMTP account (MVP — server action injects into every /send) ----
# Will be replaced by the account store in Phase 4 (DCR-NM-004).
# For Gmail: use an App Password, port 465, secure=true.
DEV_SMTP_HOST=
DEV_SMTP_PORT=465
DEV_SMTP_SECURE=true
DEV_SMTP_USER=
DEV_SMTP_PASS=
